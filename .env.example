# -----------------------------------------------------------------------------
# RMT environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. This file holds ONLY placeholders.
#
# Note: registrar API credentials (GoDaddy, Combell, …) are NOT in this file.
# They are stored encrypted in PostgreSQL and managed via the settings page in
# the UI. The single source of truth is the `registrar_credentials` table.
# -----------------------------------------------------------------------------

# --- App -----------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Master secret used to derive the Fernet key that encrypts registrar
# credentials at rest. install.sh generates a strong value automatically on
# fresh installs. For local dev, generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotating this value invalidates every stored credential — operators must
# re-enter API keys via the settings page after a rotation.
APP_SECRET=

# --- Database (PostgreSQL) -----------------------------------------------
# First create the DB and role:
#   psql -U postgres -v password='your-dev-password' -f scripts/dev/create-db.sql
# Then mirror the same password here.
DATABASE_URL=postgresql+asyncpg://rmt_dev:CHANGE_ME@localhost:5432/rmt_dev

# --- Production-only (ignored in dev) ------------------------------------
# Public FQDN used by NGINX + Let's Encrypt.
PUBLIC_FQDN=rmt.example.com
# Email address used for Let's Encrypt certificate registration.
LETSENCRYPT_EMAIL=admin@example.com
